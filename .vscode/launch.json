{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "debug",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run debug",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Attach to process",
            "type": "node",
            "request": "attach",
            "restart": true,
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "${workspaceFolder}"
        },
        {
            "name": "Zshtest",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run debug"
        }
    ]
}
